# HealthTrack Pro Backend Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# REQUIRED - Application will not start without these
# ===========================================

# MongoDB Connection
MONGO_URL=mongodb://localhost:27017
DB_NAME=healthtrack_pro

# CORS Configuration (comma-separated domains for production)
CORS_ORIGINS=*

# ===========================================
# SECURITY - Must change for production
# ===========================================

# JWT Secret (generate with: openssl rand -hex 32)
JWT_SECRET=change-this-to-a-secure-random-string

# ===========================================
# AI/LLM Integration (Optional)
# ===========================================

# Emergent Universal Key (for AI wellness, lab analysis)
EMERGENT_LLM_KEY=

# Alternative: Direct OpenAI key
OPENAI_API_KEY=

# ===========================================
# Health Platform OAuth (Optional - for real wearable sync)
# ===========================================

# Google Fit OAuth 2.0
# Get from: https://console.cloud.google.com/
GOOGLE_FIT_CLIENT_ID=
GOOGLE_FIT_CLIENT_SECRET=

# Fitbit OAuth 2.0
# Get from: https://dev.fitbit.com/
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=

# Garmin Connect OAuth 1.0a
# Get from: https://developer.garmin.com/
GARMIN_CONSUMER_KEY=
GARMIN_CONSUMER_SECRET=

# Samsung Health Partner App
SAMSUNG_HEALTH_APP_ID=

# OAuth Redirect URI (update for production)
HEALTH_OAUTH_REDIRECT_URI=https://yourdomain.com/api/health-sync/callback

# ===========================================
# Video Consulting (Optional - Twilio)
# ===========================================

# Get from: https://console.twilio.com/
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=

# ===========================================
# Payment Processing (Optional - Razorpay)
# ===========================================

# Get from: https://dashboard.razorpay.com/
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ===========================================
# Email Service (Optional - SendGrid)
# ===========================================

# Get from: https://sendgrid.com/
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# ===========================================
# SMS Service (Optional - Twilio)
# ===========================================

TWILIO_SMS_ACCOUNT_SID=
TWILIO_SMS_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ===========================================
# ABDM Integration (Optional)
# ===========================================

# Get from: https://sandbox.abdm.gov.in/
ABDM_CLIENT_ID=
ABDM_CLIENT_SECRET=
ABDM_BASE_URL=https://healthidsbx.abdm.gov.in

# ===========================================
# Application Settings
# ===========================================

# Environment: development, staging, production
ENVIRONMENT=development

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Server port (for local development)
PORT=8001

# App version (for monitoring)
APP_VERSION=1.0.0
